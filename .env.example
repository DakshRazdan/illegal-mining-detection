# ============================================================
# .env.example — Copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# --- Planetary Computer (Sentinel-2 STAC) ---
PLANETARY_COMPUTER_API_KEY=your_pc_api_key_here

# --- ASF Search (Sentinel-1 SAR) ---
ASF_USERNAME=your_asf_username
ASF_PASSWORD=your_asf_password

# --- Twilio (WhatsApp + SMS Alerts) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
TWILIO_SMS_FROM=+1XXXXXXXXXX
TWILIO_SMS_TO=+91XXXXXXXXXX

# --- PostGIS Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mining_detection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/mining_detection

# --- Flask Dashboard ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# --- FastAPI Backend ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Gemini API (optional — scene description) ---
GEMINI_API_KEY=your_gemini_api_key

# --- App Settings ---
LOG_LEVEL=INFO
SYNTHETIC_MODE=false
